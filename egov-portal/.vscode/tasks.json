{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Maven Build & Deploy",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "C:\\ST-onesIDE\\server\\apache-maven-3.9.16\\bin\\mvn.cmd clean package -DskipTests && copy /Y target\\sample-project-1.0.0.war C:\\ST-onesIDE\\server\\apache-tomcat-10.1.55\\webapps\\ROOT.war"
            ],
            "options": {
                "env": {
                    "JAVA_HOME": "C:\\ST-onesIDE\\java\\java-21"
                }
            },
            "problemMatcher": []
        },
        {
            "label": "Start Tomcat in Debug Mode",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "C:\\ST-onesIDE\\server\\apache-tomcat-10.1.55\\bin\\catalina.bat jpda run"
            ],
            "options": {
                "env": {
                    "JAVA_HOME": "C:\\ST-onesIDE\\java\\java-21",
                    "CATALINA_HOME": "C:\\ST-onesIDE\\server\\apache-tomcat-10.1.55",
                    "JPDA_ADDRESS": "8000"
                }
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^.*$",
                    "file": 1,
                    "location": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*$",
                    "endsPattern": ".*(Server startup in|서버가).*ms.*"
                }
            }
        }
    ]
}
