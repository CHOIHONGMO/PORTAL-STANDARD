{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "PortalApplication",
            "request": "launch",
            "mainClass": "com.portal.PortalApplication",
            "projectName": ""
        },
        {
            "type": "java",
            "name": "Debug eversrm (Tomcat)",
            "request": "launch",
            "mainClass": "org.apache.catalina.startup.Bootstrap",
            "args": [
                "start"
            ],
            "vmArgs": [
                "-Dcatalina.base=${workspaceFolder}\\.tomcat\\eversrm",
                "-Dcatalina.home=C:\\ST-onesIDE\\server\\apache-tomcat-10.1.55",
                "-Djava.util.logging.config.file=${workspaceFolder}\\.tomcat\\eversrm\\conf\\logging.properties",
                "-Djava.util.logging.manager=org.apache.juli.ClassLoaderLogManager",
                "-Dfile.encoding=UTF-8"
            ],
            "classPaths": [
                "C:\\ST-onesIDE\\server\\apache-tomcat-10.1.55\\bin\\bootstrap.jar",
                "C:\\ST-onesIDE\\server\\apache-tomcat-10.1.55\\bin\\tomcat-juli.jar"
            ],
            "console": "internalConsole",
            "preLaunchTask": "Maven Build & Deploy eversrm"
        }
    ]
}
